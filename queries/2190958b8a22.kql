// Source: https://github.com/DancinDinoo/KQL
// Collected: 2026-05-17
// KQL Library - https://github.com/sivolko/kql-library

SecurityEvent
| where EventID == "4697"
| extend ParsedParameters = parse_xml(EventData)
| where ServiceStartType == "3" and ServiceFileName matches regex @"\%systemroot\%\\[A-Za-z]{8}\.exe" and ServiceName matches regex @"^[a-zA-z]{4}$"

// Identifies known indicators of PsExec.py after execution
// https://github.com/fortra/impacket/tree/master 
// https://github.com/un33k/impacket/blob/master/examples/psexec.py