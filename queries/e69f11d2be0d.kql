// Source: https://github.com/CyberAutomationX/SecureAzCloud-Scripts
// Collected: 2026-05-14
// KQL Library - https://github.com/sivolko/kql-library

let Lookback = 30d;
let AIApps = dynamic(["openai", "chatgpt", "claude", "anthropic", "gemini", "copilot", "copilot studio", "azure ai", "azure openai", "cognitive services", "ai foundry", "perplexity", "mistral"]);
AuditLogs
| where TimeGenerated > ago(Lookback)
| where ActivityDisplayName has_any (dynamic(["consent to application", "grant consent to application", "add delegated permission grant", "add app role assignment to service principal"]))
| mv-expand TargetResources
| extend TargetDisplayName = tolower(tostring(TargetResources.displayName)),
         ActorUser = tostring(InitiatedBy.user.userPrincipalName),
         ActorApp = tostring(InitiatedBy.app.displayName),
         ActorIP = tostring(InitiatedBy.user.ipAddress),
         Modified = tostring(TargetResources.modifiedProperties)
| where TargetDisplayName has_any (AIApps) or Modified has_any (AIApps)
| project TimeGenerated, ActivityDisplayName, TargetDisplayName, Actor = coalesce(ActorUser, ActorApp), ActorIP, Result, ResultReason, AdditionalDetails, TargetResources
| sort by TimeGenerated desc