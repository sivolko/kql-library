// Source: https://github.com/lenoshz/active-directory-security-lab
// Collected: 2026-05-11
// KQL Library - https://github.com/sivolko/kql-library

SecurityEvent
| where TimeGenerated > ago(1h)
| where EventID == 4624
| where LogonType == 3  // Network logon
| where AuthenticationPackageName == "NTLM"
| where TargetUserName !endswith "$"  // Exclude machine accounts
// Exclude known legitimate sources
| where IpAddress !in ("192.168.1.100", "127.0.0.1", "-", "::1")
| project 
    TimeGenerated,
    TargetUserName,
    TargetDomainName,
    IpAddress,
    WorkstationName,
    LogonProcessName,
    AuthenticationPackageName
| summarize 
    LogonCount = count(),
    SourceIPs = make_set(IpAddress, 10),
    Workstations = make_set(WorkstationName, 10)
  by TargetUserName, bin(TimeGenerated, 15m)
| where LogonCount >= 1
| extend AlertDescription = strcat("NTLM logon for ", TargetUserName, " from unusual source")
| project TimeGenerated, TargetUserName, LogonCount, SourceIPs, Workstations, AlertDescription

// Alternative: Detect explicit credential logon (common with PtH tools)
