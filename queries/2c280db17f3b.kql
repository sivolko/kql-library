    ProcessName,
    IpAddress
| where SubjectUserName != TargetUserName
| summarize Count = count() by SubjectUserName, TargetUserName, TargetServerName
| where Count >= 1
*/

// Detect NTLM validation events
/*
SecurityEvent
| where TimeGenerated > ago(1h)
| where EventID == 4776
| where TargetUserName !endswith "$"
| extend SourceWorkstation = Workstation
| project TimeGenerated, TargetUserName, SourceWorkstation, Status
| summarize 
    SuccessCount = countif(Status == "0x0"),
    FailCount = countif(Status != "0x0")
  by TargetUserName, SourceWorkstation
| where SuccessCount > 0
*/

// Comprehensive PtH detection
/*
let NTLMLogons = SecurityEvent
| where TimeGenerated > ago(1h)
| where EventID == 4624 and LogonType == 3 and AuthenticationPackageName == "NTLM"
| project TimeGenerated, TargetUserName, IpAddress, EventType = "NTLM_Logon";

let ExplicitCreds = SecurityEvent
| where TimeGenerated > ago(1h)
| where EventID == 4648
| project TimeGenerated, TargetUserName, IpAddress, EventType = "Explicit_Creds";

union NTLMLogons, ExplicitCreds
| summarize EventCount = count() by TargetUserName, IpAddress, EventType
| where EventCount >= 1
*/