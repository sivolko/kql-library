// Source: https://github.com/CyberAutomationX/SecureAzCloud-Scripts
// Collected: 2026-05-10
// KQL Hunter - https://github.com/YOUR_USER/kql-hunter

let Lookback = 7d;
let AIDomains = dynamic(["openai.com", "chatgpt.com", "api.openai.com", "anthropic.com", "api.anthropic.com", "claude.ai", "gemini.google.com", "generativelanguage.googleapis.com", "makersuite.google.com", "cohere.ai", "api.cohere.ai", "mistral.ai", "api.mistral.ai", "perplexity.ai", "api.perplexity.ai", "huggingface.co", "api-inference.huggingface.co", "replicate.com", "api.replicate.com", "together.ai", "together.xyz", "fireworks.ai", "stability.ai", "grok.com", "x.ai"]);
CommonSecurityLog
| where TimeGenerated > ago(Lookback)
| extend RequestUrl_l = tolower(RequestURL),
         ParsedHost = tolower(tostring(parse_url(RequestURL).Host)),
         DstHost = tolower(DestinationHostName),
         Host = coalesce(ParsedHost, DstHost, RequestUrl_l),
         User = coalesce(SourceUserName, SourceUserID),
         Action = coalesce(SimplifiedDeviceAction, DeviceAction)
| where isnotempty(Host) and Host has_any (AIDomains)
| summarize EventCount = count(),
            DistinctUsers = dcount(User),
            DistinctSourceIPs = dcount(SourceIP),
            SampleUrls = make_set(RequestURL, 20),
            Actions = make_set(Action, 10)
    by bin(TimeGenerated, 1h), DeviceVendor, DeviceProduct
| where EventCount >= 10
| sort by EventCount desc