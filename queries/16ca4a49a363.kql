// KQL Hunter - https://github.com/YOUR_USER/kql-hunter

OfficeActivity
| where RecordType =~ "SharePointFileOperation" 
| where SourceRelativeUrl has "Microsoft Teams Chat Files" 
| where Operation =~ "FileUploaded" 
| where SourceFileExtension == "exe"