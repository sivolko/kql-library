// Source: https://github.com/julianobarbosa/claude-code-skills
// Collected: 2026-05-13
// KQL Library - https://github.com/sivolko/kql-library

CommonSecurityLog
| where TimeGenerated > ago(1h)
| where DeviceAction =~ "denied"
| summarize
    conn_count = count(),
    port_count = dcount(DestinationPort)
    by SourceIP, DestinationIP
| where port_count > 20
| order by port_count desc
| take 50