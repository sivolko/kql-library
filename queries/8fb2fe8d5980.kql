// Source: https://github.com/ge0mant1s/SOaC-Enterprise
// Collected: 2026-05-17
// KQL Library - https://github.com/sivolko/kql-library

let sensitive_patterns = dynamic([
    "BEGIN PRIVATE KEY", "AKIA", "ASIA",
    "password:", "secret_key:", "api_key:"
]);
let ai_endpoints = dynamic([
    "/v1/chat/completions", "/api/generate", "/inference"
]);
CommonSecurityLog
| where TimeGenerated > ago(1h)
| where RequestURL has_any (ai_endpoints)
| where EventOutcome == "200"
| where Message has_any (sensitive_patterns)
| extend LeakType = case(
    Message has "PRIVATE KEY", "Private Key Exposure",
    Message has "AKIA", "AWS Credential Leak",
    Message has "password:", "Credential Disclosure",
    "API Token Exposure"
)
| project TimeGenerated, SourceIP, DestinationIP, RequestURL, LeakType
| summarize LeakCount = count(), LeakTypes = make_set(LeakType),
    FirstSeen = min(TimeGenerated), LastSeen = max(TimeGenerated)
    by SourceIP, RequestURL
| sort by LeakCount desc