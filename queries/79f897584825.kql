// Source: https://github.com/rod-trent/SentinelKQL
// Collected: 2026-05-11
// KQL Library - https://github.com/sivolko/kql-library

SigninLogs //Data Source
| where TimeGenerated > ago(30d)
| where _IsBillable == true
| summarize sum(_BilledSize)
| extend TotalGB = sum__BilledSize / 1024
| extend UEBAGB = 0.07*TotalGB
| project UEBAGB